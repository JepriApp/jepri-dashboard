%% Diagrama de flujo simplificado (Mermaid) para la accion Guardar en el modal de asignar proveedores
%% Fuente: src/pages/a/distribution-plans/[id]/assign-suppliers.tsx L439-449

flowchart TD
    START([Click Guardar]) --> Q{quantity > 0}

    %% Rama cantidad > 0
    Q -- Si --> PO[PO get or create]
    PO --> PI[PI get or create or update quantity]
    PI --> FUL[Fulfillment get or create]
    FUL --> END([Fin])

    %% Rama cantidad = 0
    Q -- No --> PO0{PO exists}
    PO0 -- No --> END
    PO0 -- Si --> PI0{PI exists}
    PI0 -- No --> END
    PI0 -- Si --> DELPI[Delete PI and fulfillment]
    DELPI --> MORE{PO has more items}
    MORE -- Si --> END
    MORE -- No --> DELPO[Delete PO]
    DELPO --> END