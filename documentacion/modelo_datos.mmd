%% Diagrama ER del esquema de base de datos (Jepri Dashboard)
%% Referencia: scripts/supabase_sql.sql

erDiagram
    app_user {
        uuid id PK
        string email
        string password_hash
        enum role
        boolean is_active
        datetime last_login
        datetime created_at
        datetime updated_at
    }

    product {
        uuid id PK
        string name
        string description
        enum unit
        string main_photo
        float reference_price
        datetime created_at
    }

    supplier {
        uuid id PK
        string name
        string contact
        string phone
        uuid user_id FK
        datetime created_at
    }

    offer {
        uuid id PK
        uuid product_id FK
        uuid supplier_id FK
        float price
        boolean available
    }

    customer {
        uuid id PK
        string name
        string contact
        string phone
        uuid user_id FK
        datetime created_at
    }

    driver {
        uuid id PK
        string name
        string phone
        uuid user_id FK
        datetime created_at
    }

    coordinator {
        uuid id PK
        string name
        string phone
        uuid user_id FK
        datetime created_at
    }

    admin {
        uuid id PK
        string name
        string phone
        uuid user_id FK
        datetime created_at
    }

    sale_order {
        uuid id PK
        uuid customer_id FK
        datetime order_date
        datetime delivery_date
        enum status
        float service_fee
        float delivery_charge
        string notes
        uuid created_by
        datetime created_at
        int order_seq
        string order_code
    }

    sale_item {
        uuid id PK
        uuid sale_order_id FK
        uuid product_id FK
        float quantity
        float unit_price
        float delivered_quantity
        datetime delivered_at
        uuid delivered_by
        datetime created_at
    }

    purchase_order {
        uuid id PK
        uuid supplier_id FK
        datetime order_date
        datetime expected_delivery_date
        enum status
        string notes
        uuid created_by
        datetime created_at
        int purchase_seq
        string purchase_code
    }

    purchase_item {
        uuid id PK
        uuid purchase_order_id FK
        uuid product_id FK
        uuid supplier_id FK
        float quantity
        float estimated_price
        float actual_price
        float received_quantity
        uuid received_by
        datetime received_at
        datetime created_at
    }

    fulfillment {
        uuid id PK
        uuid sale_item_id FK
        uuid purchase_item_id FK
        float quantity
        datetime created_at
    }

    shopping_cart {
        uuid id PK
        uuid customer_id FK
        uuid product_id FK
        float quantity
        datetime created_at
        datetime updated_at
    }

    distribution_plan {
        uuid id PK
        date plan_date
        enum status
        uuid coordinator_id FK
        string notes
        datetime cutoff_at
        datetime created_at
        datetime updated_at
        int plan_seq
        string plan_code
    }

    distribution_plan_order {
        uuid id PK
        uuid distribution_plan_id FK
        uuid sale_order_id FK
        int sequence
        enum status
        datetime delivered_at
        uuid assigned_user_id FK
        datetime created_at
    }

    %% Relaciones (cardinalidades)
    supplier }o--|| app_user : user_account
    customer }o--|| app_user : user_account

    offer }o--|| product : product
    offer }o--|| supplier : supplier

    sale_order }o--|| customer : customer
    sale_item }o--|| sale_order : order
    sale_item }o--|| product : product

    purchase_order }o--|| supplier : supplier
    purchase_item }o--|| purchase_order : order
    purchase_item }o--|| product : product
    purchase_item }o--|| supplier : supplier

    fulfillment }o--|| sale_item : sale_item
    fulfillment }o--|| purchase_item : purchase_item

    shopping_cart }o--|| customer : customer
    shopping_cart }o--|| product : product

    driver }o--|| app_user : user_account
    coordinator }o--|| app_user : user_account
    admin }o--|| app_user : user_account

    distribution_plan }o--|| coordinator : coordinator

    distribution_plan_order }o--|| distribution_plan : plan
    distribution_plan_order }o--|| sale_order : sale_order

